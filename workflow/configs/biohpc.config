includeConfig 'nextflow.config'

singularity {
  enabled = true
  runOptions = ''
  cacheDir = "$baseDir/images/singularity"
}

conda.enabled = false
params.build_deskew_container = true

profiles {
    light_sheet {
        conda.enabled = false
    }
}

trace.overwrite = true
timeline.overwrite = true
report.overwrite = true
dag.overwrite = true
