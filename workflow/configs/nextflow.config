params {
    image_files = []
    input = []
    image_path = ''
    cell_name = ''
    cell_index = -1
    output_dir = './workflow/output'

    dx = -1
    dz = -1
    angle = 40
    flip = 1
    deskew_backend = 'cpu_blocked'
    z_chunk = 256
    deskew_prefetch = 64
    pyramid_max_downsample = 16
    deskew_runtime_dir = ''
    build_deskew_container = true
}

profiles {
    my_cluster {
        conda.enabled = true
    }

    light_sheet {
        conda.enabled = false
        params.angle = 40
        params.flip = 1
    }

    conda_runtime {
        conda.enabled = false
        params.build_deskew_container = true
    }
}

process {
    executor = 'slurm'

    withName: STAGE_DESKEW_INPUT {
        cpus = 2
        memory = '8 GB'
        queue = 'super'
    }

    withName: DESKEW {
        cpus = 32
        memory = '64 GB'
        queue = { ['gpu', 'cuda'].contains((params.deskew_backend ?: '').toString().trim().toLowerCase().replace('-', '_')) ? 'GPU' : 'super' }
        clusterOptions = { ['gpu', 'cuda'].contains((params.deskew_backend ?: '').toString().trim().toLowerCase().replace('-', '_')) ? '--gres=gpu:1' : '' }
    }
}
